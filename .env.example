# Public base URL of the site, e.g. https://cyrene.vercel.app (auto-set on Vercel)
AUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
AUTH_SECRET=

AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Neon pooled connection string (or local postgres for dev)
DATABASE_URL=postgres://cyrene:cyrene@localhost:5432/cyrene

# Vercel Blob (news cover uploads) — from the Vercel dashboard
BLOB_READ_WRITE_TOKEN=
